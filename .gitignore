# Dependencies
/node_modules

# Next.js build output
/.next
/out

# Production build
/build

# Environment files (local only)
.env*.local
.env.local

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Railway (local link config only — railway.json stays in repo)
/.railway

# OS
.DS_Store
*.pem
Thumbs.db

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Firebase (no longer used)
/.firebase
firebase-debug.log
serviceAccountKey.json

# Vercel (no longer used)
/.vercel

# IDE
.vscode/
.idea/

# Capacitor — ios/ is generated by CI (requires CocoaPods) and is NOT committed.
# android/ IS committed so CI can sync it directly without re-scaffolding.
/ios

# Android secrets — never commit the upload keystore
/android/app/upload.jks
# google-services.json is PUBLIC client config (safe to commit per Firebase docs).
# Kept committed so CI doesn't need a base64 secret round-trip.

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/
.env.staging
