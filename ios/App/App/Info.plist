<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  NoQx Student — iOS Info.plist
  This file is committed as a scaffold so CI can apply patches after `cap add ios`.
  `npx cap sync` merges Capacitor-generated values on top of this.
-->
<plist version="1.0">
<dict>
    <!-- App identity -->
    <key>CFBundleDisplayName</key>
    <string>NoQx Student</string>
    <key>CFBundleName</key>
    <string>NoQx Student</string>
    <key>CFBundleIdentifier</key>
    <string>com.noqx.student</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <!-- Supported orientations: portrait only (student app) -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
    </array>

    <!-- Status bar -->
    <key>UIStatusBarHidden</key>
    <false/>
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <true/>

    <!-- Launch screen -->
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>

    <!-- Main storyboard (Capacitor uses UIViewController directly) -->
    <key>UIMainStoryboardFile</key>
    <string>Main</string>

    <!-- App Transport Security: HTTPS only -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <false/>
        <key>NSExceptionDomains</key>
        <dict>
            <key>noqx.up.railway.app</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <false/>
                <key>NSIncludesSubdomains</key>
                <true/>
            </dict>
        </dict>
    </dict>

    <!-- Push notifications -->
    <key>UIBackgroundModes</key>
    <array>
        <string>remote-notification</string>
        <string>fetch</string>
    </array>

    <!-- Privacy descriptions (required by App Store review) -->
    <key>NSCameraUsageDescription</key>
    <string>NoQx uses the camera to let you scan QR codes for quick ordering.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>NoQx may save QR codes or receipts to your photo library.</string>
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>NoQx uses your location to show the nearest canteen.</string>

    <!-- Capacitor scheme -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>com.noqx.student</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>com.noqx.student</string>
            </array>
        </dict>
    </dict>

    <!-- iPad support -->
    <key>LSRequiresIPhoneOS</key>
    <false/>
</dict>
</plist>
