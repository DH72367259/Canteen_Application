<?xml version="1.0" encoding="utf-8"?>
<!-- Enforces HTTPS for all connections. The server URL is production-only HTTPS. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
