# ── Supabase (public — safe to expose) ──────────────────────────────────────
# Get from: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Supabase Admin SDK (server-side — keep SECRET) ──────────────────────────
# Get from: Supabase Dashboard -> Project Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Razorpay Payment Gateway ─────────────────────────────────────────────────
# Get from: Razorpay Dashboard → Settings → API Keys
# Use rzp_test_* keys for testing, rzp_live_* for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx
# Get from: Razorpay Dashboard → Settings → Webhooks → add endpoint → copy secret
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Twilio (server-side — keep SECRET) ───────────────────────────────────────
# Used for WhatsApp OTP delivery (SMS is handled by Supabase directly)
# Get from: Twilio Console → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get from: Twilio Console → Verify → Services → Canteen App
TWILIO_VERIFY_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Set to 'true' ONLY after WhatsApp Business is approved and connected in Twilio
# Steps to enable: Twilio Console → Verify → Canteen App → WhatsApp tab → enable
TWILIO_WHATSAPP_ENABLED=false

# ── App URL (for auth redirects) ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Cron secret (server-side — keep SECRET) ──────────────────────────────────
# Used by the daily password-expiry-notify cron job.
# Generate with: openssl rand -hex 32
# Set the same value in your Railway env vars AND in your cron scheduler's
# Authorization header:  Authorization: Bearer <CRON_SECRET>
CRON_SECRET=your-random-secret-here

# ── Resend (server-side — keep SECRET) ───────────────────────────────────────
# Used to send login OTP emails with a custom template via Resend.
# Get from: resend.com → API Keys → Create API Key
# IMPORTANT: verify your domain at resend.com → Domains before going live.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sender address — must be from a domain verified in Resend dashboard.
OTP_FROM_EMAIL=noreply@yourdomain.com
# Optional: override app name shown in OTP email subject/body
# NEXT_PUBLIC_APP_NAME=Canteen App

# ── Amazon SES — Supabase custom SMTP ────────────────────────────────────────
# Configure as Supabase custom SMTP to send password resets, magic links, etc.
# at 1-lakh-per-day scale (SES free tier: 62k/month from EC2, paid otherwise).
#
# Steps (no code changes needed — pure Supabase dashboard config):
#   1. AWS Console → SES → Verified Identities → verify your domain
#   2. Request production access (move out of sandbox) via AWS support
#   3. AWS Console → SES → SMTP Settings → Create SMTP Credentials
#   4. Supabase Dashboard → Project Settings → Auth → SMTP Settings → Enable
#        Host:       email-smtp.<your-region>.amazonaws.com
#        Port:       587  (or 465 for TLS)
#        Username:   <IAM SMTP username from step 3>
#        Password:   <IAM SMTP password from step 3>
#        Sender:     noreply@yourdomain.com  (must be SES-verified)
#   5. Supabase Dashboard → Auth → Rate Limits → increase "Email sends" limit
#
# These vars are for reference only — actual config lives in Supabase dashboard.
# SES_SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
# SES_SMTP_PORT=587
# SES_SMTP_USER=AKIAIOSFODNN7EXAMPLE
# SES_SMTP_PASS=xxxxxxxxxxxxxxxxxxxxxxxxxx
# SES_FROM_EMAIL=noreply@yourdomain.com

# ── Redis (for OTP rate limiting) ─────────────────────────────────────────────
# Required for OTP rate limiting (5/hour, 20/day per email).
# Railway: auto-injected as REDIS_URL when Redis plugin is added.
# Local: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ── Setup checklist ──────────────────────────────────────────────────────────
# 1. Create a Supabase project at https://supabase.com (free tier)
# 2. Run supabase/schema.sql in the Supabase SQL Editor
# 3. Enable Authentication providers in Supabase Dashboard -> Auth -> Providers
#    - Email OTP: enable "Email" provider
#    - Phone OTP: requires Twilio integration
# 4. Add redirect URL in Supabase Dashboard -> Auth -> URL Configuration
# 5. Create Razorpay account at https://razorpay.com and complete KYC
# 6. Resend setup (for OTP email delivery):
#    a. Create account at resend.com
#    b. Add & verify your domain (Domains → Add Domain → add DNS TXT/MX/DKIM records)
#    c. Create an API key (API Keys → Create API Key → copy to RESEND_API_KEY)
#    d. Set OTP_FROM_EMAIL to noreply@yourdomain.com
# 7. Amazon SES setup (for Supabase auth emails at scale):
#    a. AWS Console → SES → Verified Identities → Add domain → verify DNS
#    b. AWS Console → SES → Account dashboard → Request production access
#    c. AWS Console → SES → SMTP Settings → Create SMTP credentials
#    d. Supabase Dashboard → Auth → SMTP → enable + fill in SES credentials
#    e. Supabase Dashboard → Auth → Rate Limits → raise "Emails per hour" limit
# 8. Copy this file to .env.local and fill in actual values
