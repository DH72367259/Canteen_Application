{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": false,
    "esModuleInterop": true,
    "isolatedModules": false,
    "noEmit": true,
    "plugins": [],
    "types": ["jest", "node"]
  },
  "include": [
    "**/*",
    "../jest.config.ts"
  ],
  "exclude": [
    "../node_modules",
    "../.next"
  ]
}
